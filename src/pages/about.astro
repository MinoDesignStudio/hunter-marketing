<script is:inline>
// ===== Scroll header state =====
const hdr = document.getElementById('siteHeader');
const onScroll = () => hdr.classList.toggle('is-scrolled', window.scrollY > 4);
window.addEventListener('scroll', onScroll, { passive: true });
onScroll();

// ===== Reveal-on-scroll =====
const io = new IntersectionObserver((entries) => {
  entries.forEach(e => {
    if (e.isIntersecting) {
      const d = parseFloat(e.target.style.getPropertyValue('--d') || '0');
      setTimeout(() => e.target.classList.add('is-in'), d);
      io.unobserve(e.target);
    }
  });
}, { threshold: 0.12, rootMargin: '0px 0px -10% 0px' });
document.querySelectorAll('.reveal').forEach(el => io.observe(el));

// ===== Blob clip application =====
const BLOB_VARIANTS = {
  pronounced: { default: 'blob-pronounced', alt: 'blob-alt', tert: 'blob-tert', card: 'blob-card', 'card-b': 'blob-card-b', 'card-c': 'blob-card-c', wave: 'blob-wave' },
  mid:        { default: 'blob-mid',        alt: 'blob-alt', tert: 'blob-tert', card: 'blob-card', 'card-b': 'blob-card-b', 'card-c': 'blob-card-c', wave: 'blob-wave' },
  soft:       { default: 'blob-soft',       alt: 'blob-soft', tert: 'blob-soft', card: 'blob-card', 'card-b': 'blob-card-b', 'card-c': 'blob-card-c', wave: 'blob-wave' },
};
function applyBlobs(intensity) {
  const map = BLOB_VARIANTS[intensity] || BLOB_VARIANTS.pronounced;
  document.querySelectorAll('[data-blob-target]').forEach(el => {
    const variant = el.dataset.blobVariant || 'default';
    const id = map[variant] || map.default;
    el.style.clipPath = `url(#${id})`;
    el.style.webkitClipPath = `url(#${id})`;
  });
}
applyBlobs('pronounced');
</script>
