---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import '../styles/about.css';

import heroImg from '../assets/about-hero-kristy-hunter.jpg';
import howWeWorkImg from '../assets/about-kristy-hunter-founder.jpg';
import alignedAssemblyImg from '../assets/about-aligned-assembly-networking.jpg';
import thoughtLeaderImg from '../assets/about-kristy-hunter-thought-leader.jpg';
import guestSpeakerImg from '../assets/about-kristy-hunter-guest-speaker.jpg';
import panelistImg from '../assets/about-kristy-hunter-panel-moderator.jpg';
import mentorImg from '../assets/about-kristy-hunter-mentor-coach.jpg';

import partnerMino from '../assets/clients/mino.png';
import partnerOhMyDigital from '../assets/clients/ohmydigital.png';
import partnerVizr from '../assets/clients/vizr.png';
import partnerFbs from '../assets/clients/fbsconsulting.png';
import partnerCemoh from '../assets/clients/cemoh.svg';
import partnerRebeccaTaylor from '../assets/clients/rebeccataylor.png';

const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;

const calendly = 'https://calendly.com/huntermarketingco/free-15-min-marketing-consultation-call';

const deliveryPartners = [
  { name: 'Mino Design & Digital', url: 'https://minodesignanddigital.com.au/', logo: partnerMino },
  { name: 'Oh My Digital', url: 'https://ohmydigitalagency.com.au/', logo: partnerOhMyDigital },
  { name: 'VIZR', url: 'https://vizr.agency/', logo: partnerVizr },
  { name: 'FBS Consulting', url: 'https://fbsconsulting.com.au/', logo: partnerFbs },
  { name: 'Cemoh', url: 'https://cemoh.com/', logo: partnerCemoh },
  { name: 'Rebecca Taylor Photography', url: 'https://www.rebeccataylor.com.au/', logo: partnerRebeccaTaylor },
];

const pBody = 'margin:0 0 16px;font-size:16.5px;line-height:1.72;color:var(--ink-600);';
---
<BaseLayout
  title="About Kristy Hunter | Hunter Marketing Co."
  description="Meet Kristy Hunter, Fractional CMO and founder of Hunter Marketing Co. 20+ years of strategy-led marketing for professional services, manufacturing and growth-focused businesses across Australia."
  path="/about/"
  ogImage={heroImg.src}
>
<!-- SVG blob defs -->
<svg width="0" height="0" style="position:absolute" aria-hidden="true">
  <defs>
    <clipPath id="blob-pronounced" clipPathUnits="objectBoundingBox">
      <path d="M0.52,-0.02 C0.74,-0.04 0.97,0.08 0.97,0.26 C0.99,0.46 0.78,0.58 0.97,0.76 C0.99,0.96 0.66,1.06 0.42,1.02 C0.20,0.99 -0.02,0.92 -0.04,0.70 C-0.04,0.50 0.07,0.34 0.04,0.18 C0.02,0.00 0.28,0.02 0.52,-0.02 Z" />
    </clipPath>
    <clipPath id="blob-soft" clipPathUnits="objectBoundingBox">
      <path d="M0.50,0.02 C0.72,0.02 0.95,0.10 0.98,0.32 C1.02,0.55 0.97,0.78 0.82,0.92 C0.66,1.05 0.42,1.00 0.23,0.92 C0.04,0.83 0.00,0.60 0.02,0.40 C0.04,0.20 0.18,0.05 0.50,0.02 Z" />
    </clipPath>
    <clipPath id="blob-mid" clipPathUnits="objectBoundingBox">
      <path d="M0.51,0.01 C0.72,0.00 0.93,0.10 0.97,0.30 C1.02,0.51 0.95,0.72 0.84,0.88 C0.72,1.04 0.50,1.00 0.32,0.95 C0.14,0.91 0.02,0.78 0.01,0.58 C-0.01,0.39 0.07,0.21 0.21,0.10 C0.30,0.03 0.39,0.02 0.51,0.01 Z" />
    </clipPath>
    <clipPath id="blob-alt" clipPathUnits="objectBoundingBox">
      <path d="M0.44,-0.04 C0.68,-0.06 0.96,0.06 1.04,0.28 C1.12,0.52 0.94,0.76 0.86,0.94 C0.74,1.14 0.44,1.10 0.22,0.96 C0.02,0.84 -0.06,0.60 -0.02,0.38 C0.04,0.16 0.20,-0.02 0.44,-0.04 Z" />
    </clipPath>
    <clipPath id="blob-tert" clipPathUnits="objectBoundingBox">
      <path d="M0.58,-0.02 C0.84,0.04 1.06,0.20 1.02,0.46 C0.98,0.72 0.84,0.96 0.58,1.02 C0.32,1.08 0.06,0.94 -0.02,0.72 C-0.10,0.50 -0.02,0.24 0.14,0.10 C0.28,-0.02 0.40,-0.06 0.58,-0.02 Z" />
    </clipPath>
    <clipPath id="blob-card-b" clipPathUnits="objectBoundingBox">
      <path d="M0.06,0.14 C0.10,0.02 0.26,0.00 0.54,0.02 C0.82,0.04 0.96,0.02 0.98,0.14 C1.00,0.28 0.96,0.56 0.97,0.80 C0.98,0.96 0.90,1.04 0.48,1.00 C0.08,0.96 0.00,0.94 0.02,0.76 C0.04,0.52 0.02,0.26 0.06,0.14 Z" />
    </clipPath>
    <clipPath id="blob-card-c" clipPathUnits="objectBoundingBox">
      <path d="M0.02,0.18 C0.00,0.06 0.18,0.00 0.50,0.02 C0.78,0.04 0.96,0.00 1.00,0.12 C1.04,0.26 0.98,0.52 0.98,0.76 C0.98,0.94 0.86,1.02 0.52,1.00 C0.14,0.98 0.04,0.92 0.02,0.74 C0.00,0.56 0.04,0.30 0.02,0.18 Z" />
    </clipPath>
    <clipPath id="blob-card" clipPathUnits="objectBoundingBox">
      <path d="M0.04,0.10 C0.06,0.02 0.20,0.00 0.50,0.01 C0.80,0.02 0.94,0.00 0.98,0.10 C1.02,0.22 1.00,0.50 0.99,0.78 C0.98,0.96 0.92,1.02 0.50,0.99 C0.10,0.97 0.02,0.96 0.01,0.78 C0.00,0.50 0.02,0.18 0.04,0.10 Z" />
    </clipPath>
    <clipPath id="blob-wave" clipPathUnits="objectBoundingBox">
      <path d="M0.00,0.04 C0.20,-0.02 0.42,0.06 0.62,0.04 C0.82,0.02 0.94,0.00 1.00,0.06 L1.00,1.00 L0.00,1.00 Z" />
    </clipPath>
  </defs>
</svg>

<!-- ============ HEADER ============ -->
<Nav />

<!-- ============ HERO ============ -->
<section class="about-hero">
  <Image src={heroImg} class="about-hero__img" alt="Kristy Hunter, founder of Hunter Marketing Co." widths={[768, 1280, 1920]} sizes="100vw" loading="eager" fetchpriority="high" />
  <div class="about-hero__overlay" aria-hidden="true"></div>
  <div class="container" style="position:relative;z-index:2;">
    <div class="about-hero__inner reveal" style="--d:0">
      <h1 style="margin:0 0 26px;max-width:none;">Some marketers chase marketing trends and focus on activities.<span class="about-hero__tag">We hunt for the strategy underneath.</span></h1>
      <p style="font-size:18px;line-height:1.7;color:var(--ink-600);margin:0 0 30px;">Kristy Hunter is a Fractional CMO, Strategic Marketing Partner, and the founder of Hunter Marketing Co. With 20+ years of experience across agencies, funded start-ups, and large ASX-listed organisations, she works with professional services firms, manufacturing organisations, and other growth-focused businesses across Australia.</p>
      <div style="display:flex;flex-wrap:wrap;gap:14px;">
        <a href={calendly} target="_blank" rel="noopener" class="btn btn--primary btn--mustard">Book a Call with Kristy <span class="arrow">&rarr;</span></a>
        <a href="#" class="btn btn--secondary">Take the Growth Assessment</a>
      </div>
    </div>
  </div>
</section>

<!-- ============ HER STORY ============ -->
<section class="svc-intro">
  <div class="container-narrow">
    <div class="reveal" style="--d:0">
      <h2 class="svc-intro__lead">Kristy's Story</h2>
      <p class="svc-intro__body" style="max-width:900px;margin:0 auto 18px;text-align:center;">Kristy has built a career spanning 20+ years across diverse marketing and advertising roles, from independent agencies to large ASX-listed organisations. Before founding Hunter Marketing Co. in early 2018, she worked with well-known Australian brands including Queensland Cricket, Lorna Jane, the Leukaemia Foundation, and the Royal Flying Doctor Service.</p>
      <p class="svc-intro__body" style="max-width:900px;margin:0 auto 18px;text-align:center;">She founded HMC to go deeper with clients. To provide personalised direction, curated plans, and strategies built around commercial business goals.</p>
      <p class="svc-intro__body" style="max-width:900px;margin:0 auto 18px;text-align:center;">Over the past eight years, HMC has built a strong reputation working with founders, CEOs, and leadership teams across professional and creative services, manufacturing, health and wellness, facilities management, construction, technology, and more.</p>
      <p class="svc-intro__body" style="max-width:900px;margin:0 auto 18px;text-align:center;">No matter the business we work alongside, we are committed to sustainable marketing practices, working at the highest standards, educating our clients on what good marketing looks like, and delivering outcomes that genuinely move the needle.</p>
      <p class="svc-intro__body" style="max-width:900px;margin:0 auto;text-align:center;">Kristy also champions women in business and has a genuine commitment to paying it forward, supporting business owners, marketers, and emerging leaders to develop the skills and strategies to reach their own goals. It is something she cares about deeply and shows up in the work consistently.</p>
    </div>
  </div>
</section>

<!-- ============ HOW WE WORK WITH YOU ============ -->
<section class="svc-section svc-section--grey">
  <div class="container">
    <div class="svc-split reveal" style="--d:0;align-items:center;">
      <div class="svc-pf-cards">
        <h2 class="svc-title" style="margin-bottom:14px;">How we work with you</h2>
        <p style="margin:0 0 24px;font-size:16.5px;line-height:1.7;color:var(--ink-600);">We offer four ways to partner with HMC, depending on where your business is right now and what you need most.</p>
        <div class="svc-pf-steps">
          <div class="svc-pf-step">
            <span class="svc-pf-num">01</span>
            <p class="svc-pf-label">1:1 Marketing Plan in a Day</p>
          </div>
          <div class="svc-pf-step">
            <span class="svc-pf-num">02</span>
            <p class="svc-pf-label">Marketing Plan in a Day and Brand Photos</p>
          </div>
          <div class="svc-pf-step">
            <span class="svc-pf-num">03</span>
            <p class="svc-pf-label">6-12 Month Marketing Strategy and Implementation Plan</p>
          </div>
          <div class="svc-pf-step">
            <span class="svc-pf-num">04</span>
            <p class="svc-pf-label">Fractional CMO Services and Senior Marketing Leadership</p>
          </div>
        </div>
        <div style="display:flex;flex-wrap:wrap;gap:14px;margin-top:28px;">
          <a href={`${base}#services`} class="btn btn--primary btn--mustard">View Our Services <span class="arrow">&rarr;</span></a>
          <a href="#" class="btn btn--secondary">Take the Growth Assessment</a>
        </div>
      </div>
      <div class="svc-blob-wrap">
        <div class="svc-pf-media-wrap">
          <div class="svc-pf-media" data-blob-target data-blob-variant="card-b">
            <Image src={howWeWorkImg} alt="Kristy Hunter, founder of Hunter Marketing Co." style="object-position:50% 22%;" widths={[600, 1200]} sizes="(max-width: 900px) 100vw, 50vw" loading="lazy" />
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ============ WHO WE WORK WITH + WE STAY AHEAD ============ -->
<section class="svc-section" style="background:#fff;">
  <div class="container">
    <div class="svc-split reveal" style="--d:0">
      <div>
        <div class="svc-col__icon">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        </div>
        <h2 class="svc-title">Who we work with</h2>
        <p style={pBody}>HMC works best with collaborative, forward-thinking businesses that understand the power of marketing and the positive effect a well-implemented strategy can have on sales, revenue, and long-term growth.</p>
        <p style={pBody}>Our clients are typically founders, CEOs, and leadership teams who are ready to move beyond reactive marketing and invest in a strategy that works. While our current focus is strongly within professional services and manufacturing, we work across a broad range of industries and welcome enquiries from growth-focused businesses that share our values.</p>
        <p style="margin:0;font-size:16.5px;line-height:1.72;color:var(--ink-600);">Many clients come to us without in-house senior marketing leadership. Some have a team in place but need strategic direction at the top. All of them are serious about growth.</p>
      </div>
      <div>
        <div class="svc-col__icon">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>
        </div>
        <h2 class="svc-title">We stay ahead so you don't have to</h2>
        <p style={pBody}>Marketing moves fast. Platforms shift, algorithms change, new tools emerge, and what worked twelve months ago may not work today. Kristy continuously researches, tests, and implements the latest strategies, tools, and market developments so that her clients don't have to carry that burden themselves. What is working right now gets built into your strategy from the start.</p>
        <p style="margin:0 0 28px;font-size:16.5px;line-height:1.72;color:var(--ink-600);">This is one of the things that separates HMC from a traditional agency model. You get a senior strategic partner who is across the market, across the tools, and invested in making sure your business stays ahead.</p>
        <a href={calendly} target="_blank" rel="noopener" class="btn btn--primary btn--mustard">Book a Call with Kristy <span class="arrow">&rarr;</span></a>
      </div>
    </div>
  </div>
</section>

<!-- ============ TRUSTED DELIVERY PARTNERS ============ -->
<section class="svc-section svc-section--grey">
  <div class="container">
    <div class="reveal" style="--d:0;max-width:1040px;">
      <h2 class="svc-title" style="margin-bottom:16px;">Our trusted delivery partners</h2>
      <p style="margin:0;font-size:17.5px;line-height:1.65;font-weight:700;color:var(--hmc-ink);text-wrap:balance;">HMC works with a handpicked network of trusted delivery partners who are brought in when a client's needs extend beyond marketing strategy. These are senior specialists and proven operators, not&nbsp;generalists.</p>
    </div>
    <div class="svc-split reveal" style="--d:80;align-items:start;margin-top:44px;">
      <div>
        <p style="margin:0 0 14px;font-size:16px;line-height:1.7;color:var(--ink-600);"><strong>Mino Design and Digital</strong> - Brand identity, web design, and digital presence. Kristy's go-to partner for clients who need their strategy supported by exceptional creative and digital execution.</p>
        <p style="margin:0 0 14px;font-size:16px;line-height:1.7;color:var(--ink-600);"><strong>Oh My Digital</strong> - A specialist B2B digital agency delivering implementation across paid media, SEO, organic social media, and performance channels.</p>
        <p style="margin:0 0 14px;font-size:16px;line-height:1.7;color:var(--ink-600);"><strong>VIZR</strong> - A B2C specialist agency brought in when clients need sharper consumer-facing digital strategy and execution.</p>
        <p style="margin:0 0 14px;font-size:16px;line-height:1.7;color:var(--ink-600);"><strong>FBS Consulting</strong> - Senior business and operations consulting. Engaged when a client's growth challenges extend into organisational structure, process, and commercial strategy.</p>
        <p style="margin:0;font-size:16px;line-height:1.7;color:var(--ink-600);">Where relevant, Kristy also connects clients with trusted fractional advisors across sales, IT, AI automation, and legal, ensuring the right expertise is at the table at the right time.</p>
      </div>
      <div>
        <span class="eyebrow eyebrow--show about-partners__eyebrow">Our partners</span>
        <div class="about-partners">
          {deliveryPartners.map((p) => (
            <a href={p.url} target="_blank" rel="noopener" class="about-partners__item" aria-label={p.name}>
              <img src={p.logo.src} alt={`${p.name} logo`} loading="lazy" />
            </a>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ============ THE ALIGNED ASSEMBLY ============ -->
<section class="svc-section" style="background:#fff;">
  <div class="container">
    <div class="svc-split reveal" style="--d:0;align-items:center;">
      <div class="svc-blob-wrap">
        <div class="svc-pf-media-wrap">
          <div class="svc-pf-media" data-blob-target data-blob-variant="card-b">
            <Image src={alignedAssemblyImg} alt="Guests connecting at The Aligned Assembly networking breakfast in Brisbane" style="object-position:50% 12%;" widths={[600, 1200]} sizes="(max-width: 900px) 100vw, 50vw" loading="lazy" />
          </div>
        </div>
      </div>
      <div>
        <h2 class="svc-title">The Aligned Assembly</h2>
        <p style={pBody}>Kristy is the co-creator of The Aligned Assembly, a business breakfast networking event held two to three times a year in Brisbane. Designed for forward-thinking leaders and innovative service providers, The Aligned Assembly brings together people who are serious about meaningful professional and strategic connection.</p>
        <p style={pBody}>Each event centres on a curated marketing, branding or visibility theme, facilitated discussion, and introductions that lead to new aligned opportunities and partnerships.</p>
        <p style="margin:0 0 24px;font-size:16.5px;line-height:1.72;color:var(--ink-600);">Events consistently sell out. If you are interested in attending or learning more, visit the events page.</p>
        <a href={`${base}events/`} class="btn btn--primary btn--mustard">View Upcoming Events <span class="arrow">&rarr;</span></a>
      </div>
    </div>
  </div>
</section>

<!-- ============ THOUGHT LEADER ============ -->
<section class="svc-section svc-section--grey">
  <div class="container">
    <div class="svc-split reveal" style="--d:0;align-items:center;">
      <div class="svc-blob-wrap">
        <div class="svc-pf-media-wrap">
          <div class="svc-pf-media" data-blob-target data-blob-variant="card-b">
            <Image src={thoughtLeaderImg} alt="Kristy Hunter recording a marketing podcast" style="object-position:50% 18%;" widths={[600, 1200]} sizes="(max-width: 900px) 100vw, 50vw" loading="lazy" />
          </div>
        </div>
      </div>
      <div>
        <h2 class="svc-title">Thought leader and community advocate</h2>
        <p style={pBody}>Kristy is an active voice in the marketing community, collaborating with industry leaders across panels, podcasts, and webinars to share knowledge, challenge convention, and push the industry forward. She is a mentor, sponsor, and speaker, committed to surrounding herself with other leaders across women-centric and visionary organisations.</p>
        <p style="margin:0;font-size:16.5px;line-height:1.72;color:var(--ink-600);">Kristy believes in collaboration over competition. When we push each other to be the best we can be, everyone wins.</p>
      </div>
    </div>
  </div>
</section>

<!-- ============ GUEST SPEAKER ============ -->
<section class="svc-section" style="background:#fff;">
  <div class="container">
    <div class="svc-split reveal" style="--d:0;align-items:center;">
      <div class="svc-blob-wrap">
        <div class="svc-pf-media-wrap">
          <div class="svc-pf-media" data-blob-target data-blob-variant="card-b">
            <Image src={guestSpeakerImg} alt="Kristy Hunter presenting as a guest speaker at a marketing event" widths={[600, 1200]} sizes="(max-width: 900px) 100vw, 50vw" loading="lazy" />
          </div>
        </div>
      </div>
      <div>
        <h2 class="svc-title">Guest speaker</h2>
        <p style={pBody}>Kristy leads in-person and virtual events with curated industry insights on the real-world impact of emerging trends and tried-and-true strategies, sharing knowledge that empowers innovation and practical action.</p>
        <p style={pBody}>Speaking topics include marketing strategy, sustainable marketing, personal branding, and AI in marketing.</p>
        <blockquote class="about-quote">
          <p>Kristy's AI webinar addressed the importance of staying current and provided practical strategies to avoid feeling overwhelmed by the pace of AI advancements. We would be thrilled to explore the possibility of having Kristy deliver ongoing webinars for our community.</p>
          <footer>Tash Booth, Director, Future Females Australia</footer>
        </blockquote>
      </div>
    </div>
  </div>
</section>

<!-- ============ GUEST PANELIST ============ -->
<section class="svc-section svc-section--grey">
  <div class="container">
    <div class="svc-split reveal" style="--d:0;align-items:center;">
      <div class="svc-blob-wrap">
        <div class="svc-pf-media-wrap">
          <div class="svc-pf-media" data-blob-target data-blob-variant="card-b">
            <Image src={panelistImg} alt="Kristy Hunter moderating a panel discussion" widths={[600, 1200]} sizes="(max-width: 900px) 100vw, 50vw" loading="lazy" />
          </div>
        </div>
      </div>
      <div>
        <h2 class="svc-title">Guest panelist and moderator</h2>
        <p style={pBody}>Kristy adds value to panel forums and shares the spotlight with other thought leaders, fostering collaboration and enhancing industry recognition across the community. She takes on panel speaker, moderator, MC, and sponsor roles.</p>
        <blockquote class="about-quote">
          <p>Thank you for moderating today's Women in Leadership panel, you did a brilliant job, professional as always. You are truly amazing at what you do.</p>
          <footer>Kim Puxty, CEO, BSCAA</footer>
        </blockquote>
      </div>
    </div>
  </div>
</section>

<!-- ============ MENTOR AND COACH ============ -->
<section class="svc-section" style="background:#fff;">
  <div class="container">
    <div class="svc-split reveal" style="--d:0;align-items:center;">
      <div class="svc-blob-wrap">
        <div class="svc-pf-media-wrap">
          <div class="svc-pf-media" data-blob-target data-blob-variant="card-b">
            <Image src={mentorImg} alt="Kristy Hunter mentoring a marketing coordinator" widths={[600, 1200]} sizes="(max-width: 900px) 100vw, 50vw" loading="lazy" />
          </div>
        </div>
      </div>
      <div>
        <h2 class="svc-title">Mentor and coach</h2>
        <p style={pBody}>Kristy provides supportive and practical guidance that helps clients and mentees develop unique frameworks and find sustainable strategies they can use long after an engagement is over. She works with both marketing coordinators and small business owners seeking clarity, confidence, and direction.</p>
        <blockquote class="about-quote">
          <p>I've had a real shift in how I see myself professionally. I have genuine confidence now and a clearer sense of direction. I recently helped more than double the reach and website traffic for one of my clients in under a month.</p>
          <footer>Charlotte Harris, Marketing Coordinator at CEMOH</footer>
        </blockquote>
        <blockquote class="about-quote">
          <p>My biggest win has been learning that genuine, consistent content that truly aligns with a brand is what moves the numbers. These sessions have been invaluable for direction and support while I find my feet.</p>
          <footer>Rachel Taylor-Winther, Marketing Coordinator at CEMOH</footer>
        </blockquote>
      </div>
    </div>
  </div>
</section>

<!-- ============ FINAL CTA ============ -->
<section class="finalcta" id="book" data-screen-label="12 Final CTA" data-comment-anchor="finalcta">
  <div class="container">
    <div class="finalcta__inner">
      <div class="reveal">
        <span class="eyebrow">Ready when you are</span>
        <h2>Let's build marketing <span class="hl">that lasts.</span></h2>
        <p>Strategy-led, ambitious, and built around your commercial goals.</p>
      </div>
      <div class="reveal" style="--d:120;display:flex;flex-direction:column;gap:14px;align-items:flex-end;">
        <a href={calendly} target="_blank" rel="noopener" class="btn btn--primary">Book a Call with Kristy <span class="arrow">&rarr;</span></a>
        <a href="#" class="btn btn--secondary" style="background:#fff;color:var(--hmc-ink);border-color:#fff;">Take the Growth Assessment</a>
      </div>
    </div>
  </div>
</section>

<!-- ============ FOOTER ============ -->
<Footer />

<style>
  /* ===== Hero (full-bleed image, cream fade) ===== */
  .about-hero {
    position: relative;
    background: #f0eeeb;
