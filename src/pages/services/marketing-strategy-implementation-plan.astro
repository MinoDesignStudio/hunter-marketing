---
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import '../../styles/strategy.css';

import foxIcon from '../../assets/fox-icon.png';
import kristyClient from '../../assets/mpiad-kristy-client.jpg';

const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
---
<BaseLayout
  title="6-12 Month Marketing Strategy & Implementation Plan | Hunter Marketing Co."
  description="A 6-12 month marketing strategy and implementation plan for established, growth-focused businesses. Clear direction, defined priorities and disciplined execution that builds momentum."
  path="/services/marketing-strategy-implementation-plan/"
  ogImage={kristyClient.src}
>
