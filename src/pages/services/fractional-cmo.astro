        <span class="eyebrow">Ready when you are</span>
        <h2>Stop reacting. <span class="hl">Start leading.</span></h2>
        <p>Ready for marketing that works as hard as you do?</p>
        <div class="svc-crosslinks svc-crosslinks--light">
          <a href="#"><span class="arrow">→</span> Need strategy without the embedded leadership? See the <strong>6-12 Month Marketing Plan</strong></a>
          <a href={`${base}services/marketing-plan-in-a-day-brand-photos/`}><span class="arrow">→</span> Solopreneur or small business? See <strong>Marketing Plan in a Day + Brand Photos</strong> (Group Program)</a>
        </div>
      </div>
      <div class="reveal" style="--d:120">
        <a href="mailto:hello@huntermarketing.co" class="btn btn--primary">Contact us <span class="arrow">→</span></a>
      </div>
    </div>
  </div>
</section>

<!-- ============ FOOTER ============ -->
<Footer />

<script is:inline>
// ===== Scroll header state =====
const hdr = document.getElementById('siteHeader');
const onScroll = () => hdr.classList.toggle('is-scrolled', window.scrollY > 4);
window.addEventListener('scroll', onScroll, { passive: true });
onScroll();

// ===== Reveal-on-scroll =====
const io = new IntersectionObserver((entries) => {
  entries.forEach(e => {
    if (e.isIntersecting) {
      const d = parseFloat(e.target.style.getPropertyValue('--d') || '0');
      setTimeout(() => e.target.classList.add('is-in'), d);
      io.unobserve(e.target);
    }
  });
}, { threshold: 0.12, rootMargin: '0px 0px -10% 0px' });
document.querySelectorAll('.reveal').forEach(el => io.observe(el));

// ===== Blob clip application =====
const BLOB_VARIANTS = {
  pronounced: { default: 'blob-pronounced', alt: 'blob-alt', tert: 'blob-tert', card: 'blob-card', 'card-b': 'blob-card-b', 'card-c': 'blob-card-c', wave: 'blob-wave' },
  mid:        { default: 'blob-mid',        alt: 'blob-alt', tert: 'blob-tert', card: 'blob-card', 'card-b': 'blob-card-b', 'card-c': 'blob-card-c', wave: 'blob-wave' },
  soft:       { default: 'blob-soft',       alt: 'blob-soft', tert: 'blob-soft', card: 'blob-card', 'card-b': 'blob-card-b', 'card-c': 'blob-card-c', wave: 'blob-wave' },
};
function applyBlobs(intensity) {
  const map = BLOB_VARIANTS[intensity] || BLOB_VARIANTS.pronounced;
  document.querySelectorAll('[data-blob-target]').forEach(el => {
    const variant = el.dataset.blobVariant || 'default';
    const id = map[variant] || map.default;
    el.style.clipPath = `url(#${id})`;
    el.style.webkitClipPath = `url(#${id})`;
  });
}
applyBlobs('pronounced');

// ===== FAQ accordion =====
document.querySelectorAll('.faq-item__btn').forEach(btn => {
  btn.addEventListener('click', () => {
    const item = btn.closest('.faq-item');
    const wasOpen = item.classList.contains('is-open');
    document.querySelectorAll('.faq-item').forEach(x => {
      x.classList.remove('is-open');
      x.querySelector('.faq-item__btn').setAttribute('aria-expanded', 'false');
    });
    if (!wasOpen) {
      item.classList.add('is-open');
      btn.setAttribute('aria-expanded', 'true');
    }
  });
});
</script>
</BaseLayout>
