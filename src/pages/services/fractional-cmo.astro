          <div class="svc-pf-step">
            <span class="svc-pf-num">01</span>
            <p class="svc-pf-label">Solo founders and business owners</p>
          </div>
          <div class="svc-pf-step">
            <span class="svc-pf-num">02</span>
            <p class="svc-pf-label">Creative freelancers and consultants</p>
          </div>
          <div class="svc-pf-step">
            <span class="svc-pf-num">03</span>
            <p class="svc-pf-label">Marketing coordinators ready for strategic direction</p>
