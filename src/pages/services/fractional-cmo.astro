---
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import '../../styles/fcmo.css';

import foxIcon from '../../assets/fox-icon.png';
import kristyClient from '../../assets/mpiad-kristy-client.jpg';

const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
---
<BaseLayout
  title="Fractional CMO Services - Senior Marketing Leadership | Hunter Marketing Co."
  description="Senior marketing leadership for medium to large organisations. 12-month fractional CMO engagements bringing strategic direction, accountability and performance oversight. Brisbane & SEQ based."
  path="/services/fractional-cmo/"
  ogImage={kristyClient.src}
>
<!-- SVG blob defs -->
<svg width="0" height="0" style="position:absolute" aria-hidden="true">
  <defs>
    <clipPath id="blob-pronounced" clipPathUnits="objectBoundingBox">
      <path d="M0.52,-0.02 C0.74,-0.04 0.97,0.08 0.97,0.26 C0.99,0.46 0.78,0.58 0.97,0.76 C0.99,0.96 0.66,1.06 0.42,1.02 C0.20,0.99 -0.02,0.92 -0.04,0.70 C-0.04,0.50 0.07,0.34 0.04,0.18 C0.02,0.00 0.28,0.02 0.52,-0.02 Z" />
    </clipPath>
    <clipPath id="blob-soft" clipPathUnits="objectBoundingBox">
      <path d="M0.50,0.02 C0.72,0.02 0.95,0.10 0.98,0.32 C1.02,0.55 0.97,0.78 0.82,0.92 C0.66,1.05 0.42,1.00 0.23,0.92 C0.04,0.83 0.00,0.60 0.02,0.40 C0.04,0.20 0.18,0.05 0.50,0.02 Z" />
    </clipPath>
    <clipPath id="blob-mid" clipPathUnits="objectBoundingBox">
      <path d="M0.51,0.01 C0.72,0.00 0.93,0.10 0.97,0.30 C1.02,0.51 0.95,0.72 0.84,0.88 C0.72,1.04 0.50,1.00 0.32,0.95 C0.14,0.91 0.02,0.78 0.01,0.58 C-0.01,0.39 0.07,0.21 0.21,0.10 C0.30,0.03 0.39,0.02 0.51,0.01 Z" />
    </clipPath>
    <clipPath id="blob-alt" clipPathUnits="objectBoundingBox">
      <path d="M0.44,-0.04 C0.68,-0.06 0.96,0.06 1.04,0.28 C1.12,0.52 0.94,0.76 0.86,0.94 C0.74,1.14 0.44,1.10 0.22,0.96 C0.02,0.84 -0.06,0.60 -0.02,0.38 C0.04,0.16 0.20,-0.02 0.44,-0.04 Z" />
    </clipPath>
    <clipPath id="blob-tert" clipPathUnits="objectBoundingBox">
      <path d="M0.58,-0.02 C0.84,0.04 1.06,0.20 1.02,0.46 C0.98,0.72 0.84,0.96 0.58,1.02 C0.32,1.08 0.06,0.94 -0.02,0.72 C-0.10,0.50 -0.02,0.24 0.14,0.10 C0.28,-0.02 0.40,-0.06 0.58,-0.02 Z" />
    </clipPath>
    <clipPath id="blob-card-b" clipPathUnits="objectBoundingBox">
      <path d="M0.06,0.14 C0.10,0.02 0.26,0.00 0.54,0.02 C0.82,0.04 0.96,0.02 0.98,0.14 C1.00,0.28 0.96,0.56 0.97,0.80 C0.98,0.96 0.90,1.04 0.48,1.00 C0.08,0.96 0.00,0.94 0.02,0.76 C0.04,0.52 0.02,0.26 0.06,0.14 Z" />
    </clipPath>
    <clipPath id="blob-card-c" clipPathUnits="objectBoundingBox">
      <path d="M0.02,0.18 C0.00,0.06 0.18,0.00 0.50,0.02 C0.78,0.04 0.96,0.00 1.00,0.12 C1.04,0.26 0.98,0.52 0.98,0.76 C0.98,0.94 0.86,1.02 0.52,1.00 C0.14,0.98 0.04,0.92 0.02,0.74 C0.00,0.56 0.04,0.30 0.02,0.18 Z" />
    </clipPath>
    <clipPath id="blob-card" clipPathUnits="objectBoundingBox">
      <path d="M0.04,0.10 C0.06,0.02 0.20,0.00 0.50,0.01 C0.80,0.02 0.94,0.00 0.98,0.10 C1.02,0.22 1.00,0.50 0.99,0.78 C0.98,0.96 0.92,1.02 0.50,0.99 C0.10,0.97 0.02,0.96 0.01,0.78 C0.00,0.50 0.02,0.18 0.04,0.10 Z" />
    </clipPath>
    <clipPath id="blob-wave" clipPathUnits="objectBoundingBox">
      <path d="M0.00,0.04 C0.20,-0.02 0.42,0.06 0.62,0.04 C0.82,0.02 0.94,0.00 1.00,0.06 L1.00,1.00 L0.00,1.00 Z" />
    </clipPath>
    <filter id="blob-keyline" x="-8%" y="-8%" width="116%" height="116%" color-interpolation-filters="sRGB">
      <feMorphology operator="dilate" radius="7" in="SourceAlpha" result="outer"/>
      <feMorphology operator="dilate" radius="5" in="SourceAlpha" result="gap"/>
      <feComposite in="outer" in2="gap" operator="out" result="ring"/>
      <feFlood flood-color="#221C34" result="color"/>
      <feComposite in="color" in2="ring" operator="in" result="keyline"/>
      <feMerge>
        <feMergeNode in="keyline"/>
        <feMergeNode in="SourceGraphic"/>
      </feMerge>
    </filter>
  </defs>
</svg>

<!-- ============ HEADER ============ -->
<Nav />

<!-- ============ HERO ============ -->
<section class="svc-hero">
  <div class="container" style="position:relative;z-index:1;">
    <div class="reveal" style="--d:0">
      <Image src={foxIcon} alt="" class="svc-hero__fox" aria-hidden="true" width={68} densities={[1, 2]} loading="eager" />
      <span class="svc-hero__eyebrow">For Medium to Large Organisations</span>
      <h1>Fractional CMO Services - Senior Marketing Leadership</h1>
      <div><span class="svc-hero__price">12-month engagements</span> <span class="svc-hero__price">Custom proposal</span></div>
      <p class="svc-hero__sub">Brisbane &amp; SEQ Based</p>
    </div>
  </div>
  <div class="svc-hero__wave">
    <svg viewBox="0 0 1440 80" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M0,40 C320,80 720,0 1100,50 C1220,62 1340,38 1440,44 L1440,80 L0,80 Z" fill="#ffffff"/>
    </svg>
  </div>
</section>

<!-- ============ INTRO ============ -->
<section class="svc-intro">
  <div class="container-narrow">
    <div class="reveal" style="--d:0">
      <h2 class="svc-intro__lead">Go from overwhelmed and uncertain to clear and confident. In a single day.</h2>
      <p class="svc-intro__body">Spend a full day with Kristy in a focused, done-with-you session built around your business. You'll walk away with the brand and marketing foundations in place, including your ICP, improved messaging, high value offers and a clear, actionable 90 day plan you can implement yourself.</p>
    </div>
  </div>
</section>

<!-- ============ PARALLAX IMAGE ============ -->
<div class="svc-parallax" aria-hidden="true"></div>

<!-- ============ WHAT YOU'LL RECEIVE + WHAT GETS COVERED ============ -->
<div class="svc-wave">
  <svg viewBox="0 0 1440 80" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
    <path d="M0,34 C360,70 900,10 1440,50 L1440,80 L0,80 Z" fill="#f5f5f5"/>
  </svg>
</div>
<section class="svc-section svc-section--grey">
  <div class="container">
    <div class="svc-split reveal" style="--d:0">
      <div>
        <h2 class="svc-title">What You'll Receive</h2>
        <ul class="svc-checklist svc-checklist--verdigris">
          <li>30-min strategy call + pre-work before your day</li>
          <li>Full-day session in Brisbane or via Zoom (split across two sessions if needed)</li>
          <li>Brand and marketing foundations tailored to your business</li>
          <li>A complete marketing plan built on the proven MPIAD framework</li>
          <li>A follow-up accountability call to keep momentum going</li>
        </ul>
        <a href="https://calendly.com/huntermarketingco/free-15-min-marketing-consultation-call" target="_blank" rel="noopener" class="btn btn--primary btn--mustard" style="margin-top:28px;display:inline-block;">Book a discovery call &rarr;</a>
        <p class="svc-pf-disc" style="margin-top:20px;">All engagements begin with a discovery call to ensure the fit is right for both sides. We'll discuss your current situation, goals, and whether the <strong><a href="#" style="color:inherit;text-decoration:underline;">1:1 MPIAD</a></strong> is the right path forward.</p>
      </div>
      <div>
        <h2 class="svc-title">What Gets Covered on the Day</h2>
        <ul class="svc-checklist svc-checklist--verdigris">
          <li>Your unique value proposition - what makes your business the clear choice</li>
          <li>Your ideal customer - who they are, what they need, and how you solve it</li>
          <li>Your key messages - consistent, authentic communication across every channel</li>
          <li>Your offers and pricing - reviewed and refined for clarity and impact</li>
          <li>The right marketing channels for your business and goals</li>
          <li>Your 90-day action plan prioritised and ready to implement</li>
        </ul>
      </div>
    </div>
  </div>
</section>
<div class="svc-wave">
  <svg viewBox="0 0 1440 80" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
    <path d="M0,46 C400,10 900,72 1440,30 L1440,0 L0,0 Z" fill="#f5f5f5"/>
  </svg>
</div>
<!-- ============ PERFECT FOR ============ -->
<section class="svc-section" style="background:#fff;">
  <div class="container">
    <div class="svc-split reveal" style="--d:0">
      <div class="svc-pf-cards">
        <h2 class="svc-title" style="margin-bottom:20px;">Perfect for:</h2>
