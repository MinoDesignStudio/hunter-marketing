---
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import '../../styles/fcmo.css';

import foxIcon from '../../assets/fox-icon.png';
import kristyClient from '../../assets/mpiad-kristy-client.jpg';
import fcmoBlob from '../../assets/fractional-cmo-marketing-leader-presenting.jpg';

const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
---
<BaseLayout
  title="Fractional CMO Services - Senior Marketing Leadership | Hunter Marketing Co."
  description="Senior marketing leadership for medium to large organisations. 12-month fractional CMO engagements bringing strategic direction, accountability and performance oversight. Brisbane & SEQ based."
  path="/services/fractional-cmo/"
  ogImage={kristyClient.src}
>
<!-- SVG blob defs -->
<svg width="0" height="0" style="position:absolute" aria-hidden="true">
  <defs>
    <clipPath id="blob-pronounced" clipPathUnits="objectBoundingBox">
      <path d="M0.52,-0.02 C0.74,-0.04 0.97,0.08 0.97,0.26 C0.99,0.46 0.78,0.58 0.97,0.76 C0.99,0.96 0.66,1.06 0.42,1.02 C0.20,0.99 -0.02,0.92 -0.04,0.70 C-0.04,0.50 0.07,0.34 0.04,0.18 C0.02,0.00 0.28,0.02 0.52,-0.02 Z" />
    </clipPath>
    <clipPath id="blob-soft" clipPathUnits="objectBoundingBox">
      <path d="M0.50,0.02 C0.72,0.02 0.95,0.10 0.98,0.32 C1.02,0.55 0.97,0.78 0.82,0.92 C0.66,1.05 0.42,1.00 0.23,0.92 C0.04,0.83 0.00,0.60 0.02,0.40 C0.04,0.20 0.18,0.05 0.50,0.02 Z" />
    </clipPath>
    <clipPath id="blob-mid" clipPathUnits="objectBoundingBox">
      <path d="M0.51,0.01 C0.72,0.00 0.93,0.10 0.97,0.30 C1.02,0.51 0.95,0.72 0.84,0.88 C0.72,1.04 0.50,1.00 0.32,0.95 C0.14,0.91 0.02,0.78 0.01,0.58 C-0.01,0.39 0.07,0.21 0.21,0.10 C0.30,0.03 0.39,0.02 0.51,0.01 Z" />
    </clipPath>
    <clipPath id="blob-alt" clipPathUnits="objectBoundingBox">
      <path d="M0.44,-0.04 C0.68,-0.06 0.96,0.06 1.04,0.28 C1.12,0.52 0.94,0.76 0.86,0.94 C0.74,1.14 0.44,1.10 0.22,0.96 C0.02,0.84 -0.06,0.60 -0.02,0.38 C0.04,0.16 0.20,-0.02 0.44,-0.04 Z" />
    </clipPath>
    <clipPath id="blob-tert" clipPathUnits="objectBoundingBox">
      <path d="M0.58,-0.02 C0.84,0.04 1.06,0.20 1.02,0.46 C0.98,0.72 0.84,0.96 0.58,1.02 C0.32,1.08 0.06,0.94 -0.02,0.72 C-0.10,0.50 -0.02,0.24 0.14,0.10 C0.28,-0.02 0.40,-0.06 0.58,-0.02 Z" />
    </clipPath>
    <clipPath id="blob-card-b" clipPathUnits="objectBoundingBox">
      <path d="M0.06,0.14 C0.10,0.02 0.26,0.00 0.54,0.02 C0.82,0.04 0.96,0.02 0.98,0.14 C1.00,0.28 0.96,0.56 0.97,0.80 C0.98,0.96 0.90,1.04 0.48,1.00 C0.08,0.96 0.00,0.94 0.02,0.76 C0.04,0.52 0.02,0.26 0.06,0.14 Z" />
    </clipPath>
    <clipPath id="blob-card-c" clipPathUnits="objectBoundingBox">
      <path d="M0.02,0.18 C0.00,0.06 0.18,0.00 0.50,0.02 C0.78,0.04 0.96,0.00 1.00,0.12 C1.04,0.26 0.98,0.52 0.98,0.76 C0.98,0.94 0.86,1.02 0.52,1.00 C0.14,0.98 0.04,0.92 0.02,0.74 C0.00,0.56 0.04,0.30 0.02,0.18 Z" />
    </clipPath>
    <clipPath id="blob-card" clipPathUnits="objectBoundingBox">
      <path d="M0.04,0.10 C0.06,0.02 0.20,0.00 0.50,0.01 C0.80,0.02 0.94,0.00 0.98,0.10 C1.02,0.22 1.00,0.50 0.99,0.78 C0.98,0.96 0.92,1.02 0.50,0.99 C0.10,0.97 0.02,0.96 0.01,0.78 C0.00,0.50 0.02,0.18 0.04,0.10 Z" />
    </clipPath>
    <clipPath id="blob-wave" clipPathUnits="objectBoundingBox">
      <path d="M0.00,0.04 C0.20,-0.02 0.42,0.06 0.62,0.04 C0.82,0.02 0.94,0.00 1.00,0.06 L1.00,1.00 L0.00,1.00 Z" />
    </clipPath>
    <filter id="blob-keyline" x="-8%" y="-8%" width="116%" height="116%" color-interpolation-filters="sRGB">
      <feMorphology operator="dilate" radius="7" in="SourceAlpha" result="outer"/>
      <feMorphology operator="dilate" radius="5" in="SourceAlpha" result="gap"/>
      <feComposite in="outer" in2="gap" operator="out" result="ring"/>
      <feFlood flood-color="#221C34" result="color"/>
      <feComposite in="color" in2="ring" operator="in" result="keyline"/>
      <feMerge>
        <feMergeNode in="keyline"/>
        <feMergeNode in="SourceGraphic"/>
      </feMerge>
    </filter>
  </defs>
</svg>

<!-- ============ HEADER ============ -->
<Nav />

<!-- ============ HERO ============ -->
<section class="svc-hero">
  <div class="container" style="position:relative;z-index:1;">
    <div class="reveal" style="--d:0">
      <Image src={foxIcon} alt="" class="svc-hero__fox" aria-hidden="true" width={68} densities={[1, 2]} loading="eager" />
      <span class="svc-hero__eyebrow">For Medium to Large Organisations</span>
      <h1>Fractional CMO Services - Senior Marketing Leadership</h1>
      <div><span class="svc-hero__price">12-month engagements <span style="opacity:.5; padding:0 8px;">|</span> Custom proposal</span></div>
      <p class="svc-hero__sub">Brisbane &amp; SEQ Based</p>
    </div>
  </div>
  <div class="svc-hero__wave">
    <svg viewBox="0 0 1440 80" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M0,40 C320,80 720,0 1100,50 C1220,62 1340,38 1440,44 L1440,80 L0,80 Z" fill="#ffffff"/>
    </svg>
  </div>
</section>

<!-- ============ INTRO ============ -->
<section class="svc-intro">
  <div class="container-narrow">
    <div class="reveal" style="--d:0">
      <h2 class="svc-intro__lead">CMO-level thinking. Embedded leadership.<br />None of the full-time CMO cost.</h2>
      <p class="svc-intro__body">You have marketing activity happening. Campaigns going out, content being published, a team doing their best. But there's no one at senior level connecting it to revenue, holding the strategic standard, or making sure the whole function moves as one.</p>
      <p class="svc-intro__body">The results - Campaigns that don't convert. A team executing without direction. And leadership wondering why marketing spend isn't showing up in the numbers.</p>
      <p class="svc-intro__body">Hunter Marketing Co. provides Fractional CMO services for growth-stage organisations that need senior marketing leadership without the full-time executive overhead. We work alongside your team, leading the function, setting the standard, and ensuring marketing efforts are tied to a commercial result.</p>
    </div>
  </div>
</section>

<!-- ============ PARALLAX IMAGE ============ -->
<div class="svc-parallax" role="img" aria-label="Kristy Hunter collaborating with a marketing team around a table in Brisbane"></div>

<!-- ============ WHAT YOU'LL RECEIVE + WHAT GETS COVERED ============ -->
<div class="svc-wave">
  <svg viewBox="0 0 1440 80" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
    <path d="M0,34 C360,70 900,10 1440,50 L1440,80 L0,80 Z" fill="#f5f5f5"/>
  </svg>
</div>
<section class="svc-section svc-section--grey">
  <div class="container">
    <div class="svc-split reveal" style="--d:0">
      <div>
        <h2 class="svc-title">What we deliver</h2>
        <ul class="svc-checklist svc-checklist--verdigris">
          <li>Strategic marketing leadership at executive level, setting direction, priorities, and the standard your team executes to</li>
          <li>Marketing strategy development and execution oversight, built around your commercial goals, not generic best practice</li>
          <li>Team mentoring and capability building, your team does the work; we lead, coach, and elevate them</li>
          <li>Cross-functional alignment, bridging the gap between marketing, sales, product, and leadership so the whole organisation pulls in the same direction</li>
          <li>Quarterly board-level reporting and stakeholder communication, clear, commercially framed, and decision-ready</li>
          <li>AI-supported content systems where they fit your business and practical implementation</li>
        </ul>
        <a href="https://calendly.com/huntermarketingco/free-15-min-marketing-consultation-call" target="_blank" rel="noopener" class="btn btn--primary btn--mustard" style="margin-top:28px;display:inline-block;">Book a discovery call &rarr;</a>
      </div>
      <div>
        <h2 class="svc-title">This is the right engagement if&hellip;</h2>
        <ul class="svc-checklist svc-checklist--verdigris">
          <li>You're a medium-to-large organisation scaling operations and need marketing to keep pace with growth</li>
          <li>You don't have a full-time CMO, or your current interim leadership isn't providing the strategic clarity the business needs</li>
          <li>Sales and marketing are misaligned and you're losing revenue as a result</li>
          <li>Your marketing team is capable but lacks senior direction, they're executing without a clear strategy or plan</li>
          <li>You're preparing for a significant business event: a new market entry, product launch, capital raise, or brand repositioning</li>
          <li>You need someone who can report to the board, hold the team accountable, and make the hard calls</li>
        </ul>
      </div>
    </div>
  </div>
</section>
<div class="svc-wave">
  <svg viewBox="0 0 1440 80" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
    <path d="M0,46 C400,10 900,72 1440,30 L1440,0 L0,0 Z" fill="#f5f5f5"/>
  </svg>
</div>
<!-- ============ PERFECT FOR ============ -->
<section class="svc-section" style="background:#fff;">
  <div class="container">
    <div class="svc-split reveal" style="--d:0">
      <div class="svc-pf-cards">
        <h2 class="svc-title" style="margin-bottom:20px;">How the engagement works</h2>
        <p class="svc-pf-intro" style="margin:0 0 24px;">Every Fractional CMO engagement starts with a discovery phase, understanding your business, your team, your gaps, and your commercial targets. From there, we build a marketing strategy aligned to your revenue goals and begin embedding with the team.</p>
        <div class="svc-pf-steps">
          <div class="svc-pf-step">
            <span class="svc-pf-num">01</span>
            <p class="svc-pf-label"><strong>Month 1&ndash;2: Discovery, audit, stakeholder engagement and strategy development.</strong> Full review of current marketing activity, team structure, channels, and commercial alignment. Marketing and brand foundations built, and strategy presented to leadership.</p>
          </div>
          <div class="svc-pf-step">
            <span class="svc-pf-num">02</span>
            <p class="svc-pf-label"><strong>Month 3&ndash;6: Execution and leadership.</strong> Strategy in market. Weekly team leadership, campaign oversight, cross-functional alignment, and ongoing optimisation.</p>
          </div>
          <div class="svc-pf-step">
            <span class="svc-pf-num">03</span>
            <p class="svc-pf-label"><strong>Month 7&ndash;12: Momentum and capability building.</strong> Driving results, elevating team capability, quarterly board reporting, and planning the next horizon.</p>
          </div>
        </div>
        <p class="svc-pf-avail" style="color:var(--hmc-ink);">Engagements are structured over 12 months. This is intentional. Meaningful marketing transformation takes time, and short-term engagements rarely produce lasting commercial outcomes.</p>
      </div>
      <div class="svc-blob-wrap">
        <div class="svc-pf-media-wrap">
          <div class="svc-pf-media" data-blob-target data-blob-variant="card-b">
          <Image src={fcmoBlob} alt="Kristy Hunter leading a marketing strategy session with a client team" widths={[600, 1200, 1800]} sizes="(max-width: 900px) 100vw, 50vw" loading="lazy" />
          </div>
        </div>
        <div style="margin-top:32px;">
          <p style="margin:0 0 14px; font-size:17px; line-height:1.65; color:var(--hmc-verdigris); font-weight:600;">We don't hand over a strategy and disappear. We embed, lead, and keep teams accountable to outcomes.</p>
          <p style="margin:0 0 22px; font-size:17px; line-height:1.65; color:var(--hmc-verdigris);">If your organisation is ready for senior marketing leadership that's genuinely invested in your commercial results, let's talk.</p>
          <a href="https://calendly.com/huntermarketingco/free-15-min-marketing-consultation-call" target="_blank" rel="noopener" class="btn btn--primary btn--mustard" style="display:inline-block;">Book a discovery call &rarr;</a>
          <p class="svc-pf-disc" style="margin-top:20px; max-width:none; font-size:12px;">All engagements begin with a discovery call to ensure the fit is right for both sides. We'll discuss your current situation, goals, and whether a Fractional CMO engagement is the right path forward.</p>
        </div>
      </div>
    </div>
  </div>
</section>
<div class="svc-wave">
  <svg viewBox="0 0 1440 80" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
    <path d="M0,50 C360,10 960,80 1440,20 L1440,0 L0,0 Z" fill="#f5f5f5"/>
  </svg>
</div>

<!-- ============ TESTIMONIALS ============ -->
<section class="svc-testimonials">
  <div class="container">
    <div class="svc-section-head reveal" style="--d:0">
      <h2 class="svc-title">What our clients say.</h2>
    </div>
    <div class="svc-testimonials__grid reveal" style="--d:80">
      <article class="t-card">
        <div class="t-quote-mark">"</div>
        <p class="t-quote">With TPS having a loyal customer base in Australia, I wanted to elevate the brand to a new generation of clients and prepare for a new product launch. I turned to Kristy and Hunter Marketing Co., having worked with her previously across the mining and transport industries. Her ability to develop a clear strategy and bring the team along made the difference, and we retained her as a fractional CMO to guide implementation and empower the team for future growth. We're now in our third year of partnering with Kristy and are about to launch another product to market with a new campaign strategy she's developed.</p>
        <div class="t-attr">
          <span class="t-name">Greg Smyth</span>
          <span class="t-role">CEO at TPS</span>
          <span class="t-service">Manufacturing Business</span>
        </div>
      </article>
    </div>
  </div>
</section>

<!-- ============ FAQ ============ -->
<div class="svc-wave">
  <svg viewBox="0 0 1440 80" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
    <path d="M0,44 C320,80 800,6 1440,52 L1440,80 L0,80 Z" fill="#fff"/>
  </svg>
</div>
<section class="svc-faq">
  <div class="container">
    <div class="svc-faq__inner">
      <div class="reveal" style="--d:0">
        <h2 class="svc-title" style="margin-top:0">Before you book.</h2>
        <p class="section-intro" style="margin-top:24px">If you're weighing up whether we're the right fit, these are the questions we get asked most.</p>
      </div>
      <div class="faq__list reveal" style="--d:80">
      <div class="faq-item">
        <button class="faq-item__btn" aria-expanded="false">
          <span>What does "fractional" mean exactly?</span>
          <span class="faq-item__icon"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"><path d="M12 5v14M5 12h14"/></svg></span>
        </button>
        <div class="faq-item__panel"><div class="faq-item__panel-inner">Fractional means you get senior CMO-level leadership without the full-time salary, super, and overhead of an in-house executive hire. You're engaging a highly experienced marketing leader on a part-time embedded basis, typically a set number of days per week or month, depending on your needs and the scope agreed in the proposal.</div></div>
      </div>
      <div class="faq-item">
        <button class="faq-item__btn" aria-expanded="false">
          <span>Why 12 months? Can we start with a shorter engagement?</span>
          <span class="faq-item__icon"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"><path d="M12 5v14M5 12h14"/></svg></span>
        </button>
        <div class="faq-item__panel"><div class="faq-item__panel-inner">Real strategic marketing change, the kind that shows up in revenue and takes more than a few months to embed. A 12-month engagement gives us the time to build the strategy, execute it properly, iterate based on results, and build genuine capability in your team. We've found shorter engagements rarely produce outcomes either party is proud of, which is why we don't offer them.</div></div>
      </div>
      <div class="faq-item">
        <button class="faq-item__btn" aria-expanded="false">
          <span>We already have a marketing team. How does this work alongside them?</span>
          <span class="faq-item__icon"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"><path d="M12 5v14M5 12h14"/></svg></span>
        </button>
        <div class="faq-item__panel"><div class="faq-item__panel-inner">This is exactly the scenario Fractional CMO services are designed for. Your team continues doing the work, we lead, direct and support them. Think of it as giving your existing team a senior leader they haven't had. They will have someone to set the strategy, resolve the hard questions, hold the standard, and connect their work to commercial outcomes.</div></div>
      </div>
      <div class="faq-item">
        <button class="faq-item__btn" aria-expanded="false">
          <span>How is this different from hiring a marketing consultant?</span>
          <span class="faq-item__icon"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"><path d="M12 5v14M5 12h14"/></svg></span>
        </button>
        <div class="faq-item__panel"><div class="faq-item__panel-inner">A consultant typically comes in, produces a deliverable (a strategy, an audit, a recommendation), and leaves. A Fractional CMO embeds. We attend your leadership meetings, lead your marketing team, report to your board, and are accountable to results, not just to producing a document. The relationship is ongoing and operational, not advisory and arms-length.</div></div>
      </div>
      <div class="faq-item">
        <button class="faq-item__btn" aria-expanded="false">
          <span>What size organisations do you work with?</span>
          <span class="faq-item__icon"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"><path d="M12 5v14M5 12h14"/></svg></span>
        </button>
        <div class="faq-item__panel"><div class="faq-item__panel-inner">Fractional CMO engagements are suited to medium-to-large organisations, typically those with an existing marketing function (even a small one), a leadership team, and commercial targets that marketing is expected to contribute to. If you're a solopreneur or early-stage business, the 6–12 Month Marketing Strategy may be a better fit.</div></div>
      </div>
      <div class="faq-item">
        <button class="faq-item__btn" aria-expanded="false">
          <span>How is pricing structured?</span>
          <span class="faq-item__icon"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"><path d="M12 5v14M5 12h14"/></svg></span>
        </button>
        <div class="faq-item__panel"><div class="faq-item__panel-inner">Every engagement is scoped and priced individually based on the size of your organisation, the complexity of the marketing function, and the number of days per month required. We'll discuss this during the discovery call and provide a custom proposal. There are no off-the-shelf packages because your business isn't off-the-shelf.</div></div>
      </div>
      <div class="faq-item">
        <button class="faq-item__btn" aria-expanded="false">
          <span>What does success look like at the end of 12 months?</span>
          <span class="faq-item__icon"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"><path d="M12 5v14M5 12h14"/></svg></span>
        </button>
        <div class="faq-item__panel"><div class="faq-item__panel-inner">We define success criteria together at the start of the engagement, typically tied to commercial outcomes: revenue contribution, pipeline growth, market share, team capability, and brand positioning. These become the benchmarks we report against at every quarterly board review.</div></div>
      </div>
      </div>
    </div>
  </div>
</section>

<!-- ============ FINAL CTA ============ -->
<section class="finalcta" id="book" data-screen-label="12 Final CTA" data-comment-anchor="finalcta">
  <div class="container">
    <div class="finalcta__inner">
      <div class="reveal">
        <span class="eyebrow">Ready when you are</span>
        <h2>Stop reacting. <span class="hl">Start leading.</span></h2>
        <p>Ready for marketing that works as hard as you do?</p>
        <div class="svc-crosslinks svc-crosslinks--light">
          <p style="margin:0 0 2px; font-size:13px; font-weight:700; letter-spacing:0.08em; text-transform:uppercase; color:rgba(255,255,255,0.65);">Also on this site</p>
          <a href={`${base}services/marketing-strategy-implementation-plan/`}><span class="arrow">→</span> Need strategy without the embedded leadership? See the <strong>6&ndash;12 Month Marketing Plan</strong></a>
          <a href={`${base}services/marketing-plan-in-a-day/`}><span class="arrow">→</span> Solopreneur or small business? See <strong>Marketing Plan in a Day</strong></a>
        </div>
      </div>
      <div class="reveal" style="--d:120">
        <a href="mailto:hello@huntermarketing.co" class="btn btn--primary">Contact us <span class="arrow">→</span></a>
      </div>
    </div>
  </div>
</section>

<!-- ============ FOOTER ============ -->
<Footer />

<script is:inline>
// ===== Scroll header state =====
const hdr = document.getElementById('siteHeader');
const onScroll = () => hdr.classList.toggle('is-scrolled', window.scrollY > 4);
window.addEventListener('scroll', onScroll, { passive: true });
onScroll();

// ===== Reveal-on-scroll =====
const io = new IntersectionObserver((entries) => {
  entries.forEach(e => {
    if (e.isIntersecting) {
      const d = parseFloat(e.target.style.getPropertyValue('--d') || '0');
      setTimeout(() => e.target.classList.add('is-in'), d);
      io.unobserve(e.target);
    }
  });
}, { threshold: 0.12, rootMargin: '0px 0px -10% 0px' });
document.querySelectorAll('.reveal').forEach(el => io.observe(el));

// ===== Blob clip application =====
const BLOB_VARIANTS = {
  pronounced: { default: 'blob-pronounced', alt: 'blob-alt', tert: 'blob-tert', card: 'blob-card', 'card-b': 'blob-card-b', 'card-c': 'blob-card-c', wave: 'blob-wave' },
  mid:        { default: 'blob-mid',        alt: 'blob-alt', tert: 'blob-tert', card: 'blob-card', 'card-b': 'blob-card-b', 'card-c': 'blob-card-c', wave: 'blob-wave' },
  soft:       { default: 'blob-soft',       alt: 'blob-soft', tert: 'blob-soft', card: 'blob-card', 'card-b': 'blob-card-b', 'card-c': 'blob-card-c', wave: 'blob-wave' },
};
function applyBlobs(intensity) {
  const map = BLOB_VARIANTS[intensity] || BLOB_VARIANTS.pronounced;
  document.querySelectorAll('[data-blob-target]').forEach(el => {
    const variant = el.dataset.blobVariant || 'default';
    const id = map[variant] || map.default;
    el.style.clipPath = `url(#${id})`;
    el.style.webkitClipPath = `url(#${id})`;
  });
}
applyBlobs('pronounced');

// ===== FAQ accordion =====
document.querySelectorAll('.faq-item__btn').forEach(btn => {
  btn.addEventListener('click', () => {
    const item = btn.closest('.faq-item');
    const wasOpen = item.classList.contains('is-open');
    document.querySelectorAll('.faq-item').forEach(x => {
      x.classList.remove('is-open');
      x.querySelector('.faq-item__btn').setAttribute('aria-expanded', 'false');
    });
    if (!wasOpen) {
      item.classList.add('is-open');
      btn.setAttribute('aria-expanded', 'true');
    }
  });
});
</script>
</BaseLayout>
