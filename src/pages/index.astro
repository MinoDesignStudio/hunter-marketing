<!-- ============ APP SCRIPTS ============ -->
<script is:inline>
// ===== iPad 3D tilt on mousemove =====
(function() {
  const media = document.querySelector('.leadmag__media--illustration');
  if (!media) return;
  const svg = media.querySelector('svg');
  if (!svg) return;
  const BASE = { ry: -8, rx: 4 };
  const MAX = 10;
  let tgt = { ry: BASE.ry, rx: BASE.rx };
  let cur = { ry: BASE.ry, rx: BASE.rx };
  function lerp(a, b, t) { return a + (b - a) * t; }
  function tick() {
    cur.ry = lerp(cur.ry, tgt.ry, 0.07);
    cur.rx = lerp(cur.rx, tgt.rx, 0.07);
    svg.style.transform = 'rotateY(' + cur.ry.toFixed(2) + 'deg) rotateX(' + cur.rx.toFixed(2) + 'deg)';
    requestAnimationFrame(tick);
  }
  media.addEventListener('mousemove', function(e) {
    const r = media.getBoundingClientRect();
    const nx = (e.clientX - r.left - r.width / 2) / (r.width / 2);
    const ny = (e.clientY - r.top - r.height / 2) / (r.height / 2);
    tgt.ry = nx * MAX;
    tgt.rx = -ny * MAX * 0.5;
  });
  media.addEventListener('mouseleave', function() {
    tgt = { ry: BASE.ry, rx: BASE.rx };
  });
  requestAnimationFrame(tick);
})();

// ===== Scroll header state =====
const hdr = document.getElementById('siteHeader');
const onScroll = () => hdr.classList.toggle('is-scrolled', window.scrollY > 4);
window.addEventListener('scroll', onScroll, { passive: true });
onScroll();

// ===== Reveal-on-scroll =====
const io = new IntersectionObserver((entries) => {
  entries.forEach(e => {
    if (e.isIntersecting) {
      const d = parseFloat(e.target.style.getPropertyValue('--d') || '0');
      setTimeout(() => e.target.classList.add('is-in'), d);
      io.unobserve(e.target);
    }
  });
}, { threshold: 0.12, rootMargin: '0px 0px -10% 0px' });
document.querySelectorAll('.reveal').forEach(el => io.observe(el));

// ===== Typewriter =====
function typewriterEffect(el, speed = 80) {
  const original = el.innerHTML;
  el.innerHTML = '';
  el.classList.add('typing');
  let i = 0;
  function step() {
    if (i >= original.length) { el.classList.add('done'); return; }
    if (original[i] === '<') {
      const close = original.indexOf('>', i);
      i = close + 1;
      el.innerHTML = original.slice(0, i);
      step();
    } else {
      i++;
      el.innerHTML = original.slice(0, i);
      setTimeout(step, speed);
    }
  }
  step();
}
const twIO = new IntersectionObserver((entries) => {
  entries.forEach(e => {
    if (e.isIntersecting) { typewriterEffect(e.target); twIO.unobserve(e.target); }
  });
}, { threshold: 0.5 });
document.querySelectorAll('[data-typewriter]').forEach(el => twIO.observe(el));

// ===== Hero CTA shake =====
(function() {
  const btn = document.getElementById('hero-cta-shake');
  if (!btn) return;
  function shake() {
    btn.classList.remove('shake');
    void btn.offsetWidth; // force reflow so animation restarts
    btn.classList.add('shake');
  }
  setTimeout(function() {
    shake();
    setInterval(shake, 10000);
  }, 5000);
})();

// ===== Blob clip application =====
// 'card' (router cards) and 'wave' (how-we-work step images) keep their fixed shape
// regardless of the blobIntensity tweak so the layout stays consistent.
const BLOB_VARIANTS = {
  pronounced: { default: 'blob-pronounced', alt: 'blob-alt', tert: 'blob-tert', card: 'blob-card', 'card-b': 'blob-card-b', 'card-c': 'blob-card-c', wave: 'blob-wave' },
  mid:        { default: 'blob-mid',        alt: 'blob-alt', tert: 'blob-tert', card: 'blob-card', 'card-b': 'blob-card-b', 'card-c': 'blob-card-c', wave: 'blob-wave' },
  soft:       { default: 'blob-soft',       alt: 'blob-soft', tert: 'blob-soft', card: 'blob-card', 'card-b': 'blob-card-b', 'card-c': 'blob-card-c', wave: 'blob-wave' },
};
function applyBlobs(intensity) {
  const map = BLOB_VARIANTS[intensity] || BLOB_VARIANTS.pronounced;
  document.querySelectorAll('[data-blob-target]').forEach(el => {
    const variant = el.dataset.blobVariant || 'default';
    const id = map[variant] || map.default;
    el.style.clipPath = `url(#${id})`;
    el.style.webkitClipPath = `url(#${id})`;
  });
}

// ===== Number count-up =====
const numIO = new IntersectionObserver((entries) => {
  entries.forEach(e => {
    if (!e.isIntersecting) return;
    const el = e.target;
    const target = parseInt(el.dataset.count, 10);
    const dur = 1400;
    const start = performance.now();
    const step = (now) => {
      const t = Math.min(1, (now - start) / dur);
      const eased = 1 - Math.pow(1 - t, 3);
      const val = Math.round(target * eased);
      el.textContent = target >= 1000 ? val.toLocaleString('en-AU') : val.toString();
      if (t < 1) requestAnimationFrame(step);
    };
    requestAnimationFrame(step);
    numIO.unobserve(el);
  });
}, { threshold: 0.5 });
document.querySelectorAll('[data-count]').forEach(el => numIO.observe(el));

// ===== Testimonials carousel =====
(function initCarousel(){
  const track = document.getElementById('tTrack');
  const prev = document.getElementById('tPrev');
  const next = document.getElementById('tNext');
  const dotsWrap = document.getElementById('tDots');
  if (!track) return;
  const cards = track.children;
  const total = cards.length;
  let visible = 3;
  const updateVisible = () => {
    const w = window.innerWidth;
    visible = w < 640 ? 1 : w < 1080 ? 2 : 3;
  };
  let index = 0;
  const pages = () => Math.max(1, total - visible + 1);
  const render = () => {
    updateVisible();
    if (index > pages() - 1) index = pages() - 1;
    const card = cards[0];
    const cardW = card.getBoundingClientRect().width;
    const gap = parseFloat(getComputedStyle(track).gap) || 24;
    track.style.transform = `translateX(${-(cardW + gap) * index}px)`;
    prev.disabled = index === 0;
    next.disabled = index >= pages() - 1;
    // dots
    dotsWrap.innerHTML = '';
    for (let i = 0; i < pages(); i++) {
      const d = document.createElement('button');
      d.className = 't-dot' + (i === index ? ' is-active' : '');
      d.setAttribute('aria-label', `Go to testimonial ${i+1}`);
      d.addEventListener('click', () => { index = i; render(); });
      dotsWrap.appendChild(d);
    }
  };
  prev.addEventListener('click', () => { index = Math.max(0, index - 1); render(); });
  next.addEventListener('click', () => { index = Math.min(pages() - 1, index + 1); render(); });
  window.addEventListener('resize', render);
  render();
})();

// ===== FAQ accordion =====
document.querySelectorAll('.faq-item__btn').forEach(btn => {
  btn.addEventListener('click', () => {
    const item = btn.closest('.faq-item');
    const wasOpen = item.classList.contains('is-open');
    document.querySelectorAll('.faq-item').forEach(x => {
      x.classList.remove('is-open');
      x.querySelector('.faq-item__btn').setAttribute('aria-expanded', 'false');
    });
    if (!wasOpen) {
      item.classList.add('is-open');
      btn.setAttribute('aria-expanded', 'true');
    }
  });
});

applyBlobs('pronounced');
</script>
</BaseLayout>
