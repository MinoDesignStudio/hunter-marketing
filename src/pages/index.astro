---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import '../styles/home.css';

import heroKristy from '../assets/hero-kristy.jpg';
import iconMustard from '../assets/icon-mustard.png';
import routerSoloFounder from '../assets/router-solo-founder.jpg';
import routerCeoStrategy from '../assets/router-ceo-strategy.jpg';
import routerFractionalCmo from '../assets/router-fractional-cmo.jpg';
import casestudyTps from '../assets/casestudy-tps.jpg';
import blogConsistency from '../assets/blog-consistency.jpg';
import blogFractionalCmo from '../assets/blog-fractional-cmo.jpg';
import blogAiVoice from '../assets/blog-ai-voice.jpg';

import clientTps from '../assets/clients/tps.png';
import clientDchouse from '../assets/clients/dchouse.png';
import clientPackagedit from '../assets/clients/packagedit.png';
import clientRitualhaus from '../assets/clients/ritualhaus.png';
import clientBscaa from '../assets/clients/bscaa.svg';
import clientStudyworkgrow from '../assets/clients/studyworkgrow.png';
import clientSecureminded from '../assets/clients/secureminded.png';
import clientSpsfacilities from '../assets/clients/spsfacilities.svg';
import clientParamco from '../assets/clients/paramco.png';
import clientFuturefemales from '../assets/clients/futurefemales.png';
import clientUrbanmetal from '../assets/clients/urbanmetal.png';
import clientNurturingconfidence from '../assets/clients/nurturingconfidence.png';
import clientSociallyconstructed from '../assets/clients/sociallyconstructed.png';
import clientThesolomons from '../assets/clients/thesolomons.png';
import clientElenidracakis from '../assets/clients/elenidracakis.png';
import clientWinningmedia from '../assets/clients/winningmedia.svg';
import clientShifft from '../assets/clients/shifft.svg';
import clientMcs from '../assets/clients/mcs.png';
import clientSteinart from '../assets/clients/steinart.png';
import clientOladigital from '../assets/clients/oladigital.png';
import clientJackimcpherson from '../assets/clients/jackimcpherson.png';
import clientCemoh from '../assets/clients/cemoh.svg';
import clientMino from '../assets/clients/mino.png';
import partnerRebeccaTaylor from '../assets/clients/rebeccataylor.png';
import partnerOhMyDigital from '../assets/clients/ohmydigital.png';
import partnerVizr from '../assets/clients/vizr.png';
import partnerFbs from '../assets/clients/fbsconsulting.png';

const clients = [
  { name: 'TPS', url: 'https://tps.com.au/', logo: clientTps },
  { name: 'DC House Design & Construction', url: 'https://dchouse.com.au/fast-track-granny-flats/', logo: clientDchouse },
  { name: 'Packaged I.T.', url: 'https://www.packagedit.com.au/', logo: clientPackagedit },
  { name: 'Ritual Haus', url: 'https://ritualhaus.com.au/', logo: clientRitualhaus },
  { name: 'BSCAA', url: 'https://bscaa.com/', logo: clientBscaa },
  { name: 'Study Work Grow', url: 'https://studyworkgrow.com/', logo: clientStudyworkgrow },
  { name: 'Secure Minded', url: 'https://www.secureminded.au/', logo: clientSecureminded, mod: 'lgwide' },
  { name: 'SPS Facilities', url: 'https://www.spsfacilities.com/', logo: clientSpsfacilities },
  { name: 'ParamCo', url: 'https://paramco.com.au/', logo: clientParamco },
  { name: 'Future Females Australia', url: 'https://futurefemalesaustralia.com.au/', logo: clientFuturefemales },
  { name: 'Urban Metal', url: 'https://www.urbanmetal.com.au/', logo: clientUrbanmetal },
  { name: 'Nurturing Confidence', url: 'https://www.nurturingconfidence.com.au/', logo: clientNurturingconfidence },
  { name: 'Socially Constructed', url: 'https://www.socially-constructed.com/index', logo: clientSociallyconstructed },
  { name: 'The Solomons Capital', url: 'https://thesolomons.com.au/capital/', logo: clientThesolomons },
  { name: 'Eleni Dracakis', url: 'https://elenidracakis.co/', logo: clientElenidracakis },
  { name: 'Winning Media', url: 'https://www.winningmedia.com.au/', logo: clientWinningmedia },
  { name: 'Shifft', url: 'https://shifft.com.au/', logo: clientShifft },
  { name: 'McConachie Stedman', url: 'https://www.mcs.au/', logo: clientMcs, mod: 'lg' },
  { name: 'SteinArt', url: 'https://steinart.com.au/', logo: clientSteinart },
  { name: 'Ola Digital', url: 'https://oladigital.co/', logo: clientOladigital },
  { name: 'Jacki McPherson Occupational Therapy', url: 'https://www.jackimcpherson.com.au/', logo: clientJackimcpherson, mod: 'wide' },
  { name: 'Cemoh', url: 'https://cemoh.com/', logo: clientCemoh },
  { name: 'Mino Design & Digital', url: 'https://minodesignanddigital.com.au/', logo: clientMino },
];

const partners = [
  { name: 'Rebecca Taylor Photography', url: 'https://www.rebeccataylor.com.au/', logo: partnerRebeccaTaylor },
  { name: 'Oh My Digital', url: 'https://ohmydigitalagency.com.au/', logo: partnerOhMyDigital },
  { name: 'VIZR', url: 'https://vizr.agency/', logo: partnerVizr },
  { name: 'Cemoh', url: 'https://cemoh.com/', logo: clientCemoh },
  { name: 'FBS Consulting', url: 'https://fbsconsulting.com.au/', logo: partnerFbs },
  { name: 'Mino Design & Digital', url: 'https://minodesignanddigital.com.au/', logo: clientMino },
];

const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
---
<BaseLayout
  title="Marketing Strategy & Fractional Services Brisbane | Hunter Marketing Co."
  description="Strategic marketing partnership for ambitious business owners and growth-focused organisations. Senior leadership, proven frameworks, sustainable momentum. Brisbane-based, Australia-wide."
  path="/"
  ogImage={heroKristy.src}
>
<svg width="0" height="0" style="position:absolute" aria-hidden="true">
  <defs>
    <!-- pronounced blob: very wobbly, organic — right side wobbles within bounds -->
    <clipPath id="blob-pronounced" clipPathUnits="objectBoundingBox">
      <path d="M0.52,-0.02 C0.74,-0.04 0.97,0.08 0.97,0.26 C0.99,0.46 0.78,0.58 0.97,0.76 C0.99,0.96 0.66,1.06 0.42,1.02 C0.20,0.99 -0.02,0.92 -0.04,0.70 C-0.04,0.50 0.07,0.34 0.04,0.18 C0.02,0.00 0.28,0.02 0.52,-0.02 Z" />
    </clipPath>
    <!-- soft blob: closer to a round square -->
    <clipPath id="blob-soft" clipPathUnits="objectBoundingBox">
      <path d="M0.50,0.02 C0.72,0.02 0.95,0.10 0.98,0.32 C1.02,0.55 0.97,0.78 0.82,0.92 C0.66,1.05 0.42,1.00 0.23,0.92 C0.04,0.83 0.00,0.60 0.02,0.40 C0.04,0.20 0.18,0.05 0.50,0.02 Z" />
    </clipPath>
    <!-- mid blob -->
    <clipPath id="blob-mid" clipPathUnits="objectBoundingBox">
      <path d="M0.51,0.01 C0.72,0.00 0.93,0.10 0.97,0.30 C1.02,0.51 0.95,0.72 0.84,0.88 C0.72,1.04 0.50,1.00 0.32,0.95 C0.14,0.91 0.02,0.78 0.01,0.58 C-0.01,0.39 0.07,0.21 0.21,0.10 C0.30,0.03 0.39,0.02 0.51,0.01 Z" />
    </clipPath>
    <!-- secondary blob (varied, very wobbly) -->
    <clipPath id="blob-alt" clipPathUnits="objectBoundingBox">
      <path d="M0.44,-0.04 C0.68,-0.06 0.96,0.06 1.04,0.28 C1.12,0.52 0.94,0.76 0.86,0.94 C0.74,1.14 0.44,1.10 0.22,0.96 C0.02,0.84 -0.06,0.60 -0.02,0.38 C0.04,0.16 0.20,-0.02 0.44,-0.04 Z" />
    </clipPath>
    <!-- tertiary blob (very wobbly) -->
    <clipPath id="blob-tert" clipPathUnits="objectBoundingBox">
      <path d="M0.58,-0.02 C0.84,0.04 1.06,0.20 1.02,0.46 C0.98,0.72 0.84,0.96 0.58,1.02 C0.32,1.08 0.06,0.94 -0.02,0.72 C-0.10,0.50 -0.02,0.24 0.14,0.10 C0.28,-0.02 0.40,-0.06 0.58,-0.02 Z" />
    </clipPath>
    <!-- card blob B: slightly different wobble for middle router card -->
    <clipPath id="blob-card-b" clipPathUnits="objectBoundingBox">
      <path d="M0.06,0.14 C0.10,0.02 0.26,0.00 0.54,0.02 C0.82,0.04 0.96,0.02 0.98,0.14 C1.00,0.28 0.96,0.56 0.97,0.80 C0.98,0.96 0.90,1.04 0.48,1.00 C0.08,0.96 0.00,0.94 0.02,0.76 C0.04,0.52 0.02,0.26 0.06,0.14 Z" />
    </clipPath>
    <!-- card blob C: third router card variant — leans right, rounder top-left -->
    <clipPath id="blob-card-c" clipPathUnits="objectBoundingBox">
      <path d="M0.02,0.18 C0.00,0.06 0.18,0.00 0.50,0.02 C0.78,0.04 0.96,0.00 1.00,0.12 C1.04,0.26 0.98,0.52 0.98,0.76 C0.98,0.94 0.86,1.02 0.52,1.00 C0.14,0.98 0.04,0.92 0.02,0.74 C0.00,0.56 0.04,0.30 0.02,0.18 Z" />
    </clipPath>
    <!-- card blob: subtler, for the router cards -->
    <clipPath id="blob-card" clipPathUnits="objectBoundingBox">
      <path d="M0.04,0.10 C0.06,0.02 0.20,0.00 0.50,0.01 C0.80,0.02 0.94,0.00 0.98,0.10 C1.02,0.22 1.00,0.50 0.99,0.78 C0.98,0.96 0.92,1.02 0.50,0.99 C0.10,0.97 0.02,0.96 0.01,0.78 C0.00,0.50 0.02,0.18 0.04,0.10 Z" />
    </clipPath>
    <!-- step blob: a wide, top-aligned wavy banner shape for the how-we-work step images -->
    <clipPath id="blob-wave" clipPathUnits="objectBoundingBox">
      <path d="M0.00,0.04 C0.20,-0.02 0.42,0.06 0.62,0.04 C0.82,0.02 0.94,0.00 1.00,0.06 L1.00,1.00 L0.00,1.00 Z" />
    </clipPath>
    <!-- Blob-following keyline filter: dilates the clipped blob shape to form a crisp ring -->
    <filter id="blob-keyline" x="-8%" y="-8%" width="116%" height="116%" color-interpolation-filters="sRGB">
      <feMorphology operator="dilate" radius="7" in="SourceAlpha" result="outer"/>
      <feMorphology operator="dilate" radius="5" in="SourceAlpha" result="gap"/>
      <feComposite in="outer" in2="gap" operator="out" result="ring"/>
      <feFlood flood-color="#221C34" result="color"/>
      <feComposite in="color" in2="ring" operator="in" result="keyline"/>
      <feMerge>
        <feMergeNode in="keyline"/>
        <feMergeNode in="SourceGraphic"/>
      </feMerge>
    </filter>
  </defs>
</svg>

<!-- ============ HEADER ============ -->
<Nav />

<!-- ============ HERO VERSION B ============ -->
<section class="hero hero--fullbg" data-screen-label="01B Hero (Full BG)" style="position:relative;">
  <Image src={heroKristy} class="hero-fullbg__img" alt="Kristy from Hunter Marketing" widths={[768, 1280, 1920]} sizes="100vw" loading="eager" fetchpriority="high" />
  <div class="container">
    <div class="hero-fullbg__inner reveal" style="--d:0">
      <h1>Your trusted guide to smart and <span class="hl">sustainable</span> marketing that drives lasting growth.</h1>
      <p class="hero__subhead">For ambitious business owners and growth-focused leaders who are tired of reactive marketing and stop-start growth.</p>
      <div class="hero__services">
        <div class="hero__services-row">
          <span>Fractional CMO services</span>
          <span class="hero__services-line" aria-hidden="true"></span>
          <span>Marketing strategy &amp; planning</span>
        </div>
        <div class="hero__services-row">
          <span>Implementation support</span>
          <span class="hero__services-line" aria-hidden="true"></span>
          <span>Strategic advisory</span>
        </div>
      </div>
      <div class="hero__ctas">
        <a href="#" class="btn btn--primary btn--mustard" id="hero-cta-shake">Take the growth assessment <span class="arrow">→</span></a>
        <a href="#book" class="btn btn--secondary">Book a strategy call</a>
      </div>
    </div>
  </div>
  <Image src={iconMustard} alt="" class="fox-watermark" aria-hidden="true" width={520} densities={[1, 2]} loading="eager" />
</section>


<!-- ============ PROOF BAR ============ -->
<section class="proof" data-screen-label="02 Proof" data-comment-anchor="proof">
  <div class="proof__wave" aria-hidden="true">
    <svg viewBox="0 0 1440 80" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M0,52 C320,80 720,6 1100,60 C1220,72 1340,48 1440,54 L1440,80 L0,80 Z" fill="#fff"/>
    </svg>
  </div>
  <div class="container">
    <div class="proof__grid">
      <div class="proof__cell reveal">
        <div class="proof__num"><span data-count="20">0</span><span class="proof__suffix">+&nbsp;years</span></div>
        <p class="proof__label">Brand and marketing experience</p>
      </div>
      <div class="proof__cell reveal" style="--d:80">
        <div class="proof__num"><span data-count="10">0</span><span class="proof__suffix">industries</span></div>
        <p class="proof__label">Cross-sector strategic perspective</p>
      </div>
      <div class="proof__cell reveal" style="--d:160">
        <div class="proof__num"><span data-count="12">0</span><span class="proof__suffix">mentees</span></div>
        <p class="proof__label">Investing in the people who will shape the industry</p>
      </div>
      <div class="proof__cell reveal" style="--d:240">
        <div class="proof__num"><span data-count="80">0</span><span class="proof__suffix">clients</span></div>
        <p class="proof__label">Trusted by founders and leadership teams</p>
      </div>
    </div>
  </div>
  <div class="proof__wave-out" aria-hidden="true">
    <svg viewBox="0 0 1440 80" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M0,26 C280,6 600,72 960,28 C1160,8 1320,54 1440,34 L1440,80 L0,80 Z" fill="#f7f7f7"/>
    </svg>
  </div>
</section>

<!-- ============ ROUTER ============ -->
<section class="router" id="services" data-screen-label="03 Where are you" data-comment-anchor="router">
  <div class="container">
    <div class="router__head reveal">
      <h2 class="section-title">Where are you right now?</h2>
      <p class="router__subhead">Find the right next step for your business.</p>
    </div>
    <div class="router__grid">
      <div class="router-card reveal" style="--d:0">
        <div class="router-card__media-wrap">
        <div class="router-card__media" data-blob-target data-blob-variant="card-b">
          <Image src={routerSoloFounder} alt="Kristy from Hunter Marketing Co. smiling while taking a phone call at a desk" widths={[480, 800, 1200]} sizes="(max-width: 1080px) 62vw, 260px" loading="lazy" />
        </div>
        </div>
        <div class="router-card__content">
        <h3 class="router-card__title">I'm a solo founder or business owner, and I need a clear plan I can run myself.</h3>
        <p class="router-card__body">You're doing bits and pieces, but nothing's connected. In one day, we'll build a practical, strategic marketing plan you can actually run.</p>
        <div style="display:flex;flex-direction:column;gap:10px;align-items:flex-start;">
          <a href={`${base}services/marketing-plan-in-a-day/`} class="router-card__cta" style="white-space:nowrap;font-size:14px;padding:10px 15px;">See 1:1 Marketing Plan in a Day</a>
          <a href={`${base}services/marketing-plan-in-a-day-brand-photos/`} class="router-card__cta" style="white-space:nowrap;font-size:14px;padding:10px 15px;">See Marketing Plan in a Day and Brand Photos</a>
        </div>
        </div>
      </div>
      <div class="router-card reveal" style="--d:120">
        <div class="router-card__media-wrap">
        <div class="router-card__media" data-blob-target data-blob-variant="card-b">
          <Image src={routerCeoStrategy} alt="Kristy leading a marketing strategy meeting with two team members in a boardroom" widths={[480, 800, 1024]} sizes="(max-width: 1080px) 62vw, 260px" loading="lazy" />
        </div>
        </div>
        <div class="router-card__content">
        <h3 class="router-card__title">I'm a CEO or business owner ready to fix my marketing for&nbsp;good.</h3>
        <p class="router-card__body">You've built a business that's working, but marketing has felt reactive and growth has been harder than it should be. You need a 6–12 month strategy that gets done properly, and keeps your business growing.</p>
        <a href="/services#strategy" class="router-card__cta" style="white-space:nowrap;font-size:14px;padding:10px 15px;">See 6-12 month marketing strategy</a>
        </div>
      </div>
      <div class="router-card reveal" style="--d:240">
        <div class="router-card__media-wrap">
        <div class="router-card__media" data-blob-target data-blob-variant="card-b">
          <Image src={routerFractionalCmo} alt="Kristy walking and talking with a business leader outside an office building" widths={[480, 800, 1200]} sizes="(max-width: 1080px) 62vw, 260px" loading="lazy" />
        </div>
        </div>
        <div class="router-card__content">
        <h3 class="router-card__title">I'm a CEO, MD, or Head of Sales who needs senior marketing leadership.</h3>
        <p class="router-card__body">You have marketing activity happening, but no one senior connecting it to revenue or giving your team clear direction. You need CMO-level thinking and leadership, without the full-time cost.</p>
        <a href="/services#fractional" class="router-card__cta" style="white-space:nowrap;font-size:14px;padding:10px 15px;">See Fractional CMO services</a>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ============ FEATURED BARRIER ============ -->
<section class="barrier" id="featuredBarrier" data-screen-label="04 The real barrier" data-comment-anchor="barrier">
  <div class="container">
    <div class="barrier__inner">
      <div class="reveal">
        <span class="eyebrow">The real barrier to growth</span>
        <h2 class="barrier__quote" data-typewriter>Strategy isn't the hard part. <span class="hl">Implementing it consistently</span> is.</h2>
      </div>
      <div class="barrier__body reveal" style="--d:120">
        <p>Most business owners know they need a marketing strategy. What they don't realise, until they've lived it, is that the strategy is just the starting line.</p>
        <p>A plan sitting in a drawer doesn't generate leads. A plan that gets implemented week after week, even imperfectly, is what builds the brand presence, the audience trust, and the pipeline you're tracking.</p>
        <p>The businesses winning online aren't always the most creative. They're the most consistent. They stay focused on the target, they know when to pounce, and they don't stop moving. That's the gap most owners don't see coming. It's also the gap we're built to close.</p>
        <p><strong>Good marketing doesn't chase. It hunts.</strong></p>
      </div>
    </div>
  </div>
</section>

<!-- ============ HOW WE WORK ============ -->
<section class="how" id="how" data-screen-label="05 How we work" data-comment-anchor="how">
  <div class="container">
    <div class="how__head reveal">
      <h2 class="section-title">How we work</h2>
      <p class="how__subhead">Most businesses don't need more marketing. They need an expert to lead it.</p>
    </div>
    <div class="how__steps">
      <div class="how-step reveal" style="--d:0">
        <div class="how-step__num">01</div>
        <h3 class="how-step__title">Audit and uncover</h3>
        <p class="how-step__body">We assess your current marketing, your market, and your competitors to find the gaps, the opportunities, and the sharpest path to differentiation.</p>
      </div>
      <div class="how-step reveal" style="--d:350">
        <div class="how-step__num">02</div>
        <h3 class="how-step__title">Workshop and strategise</h3>
        <p class="how-step__body">We share the research insights and run a collaborative session to align on direction, so the strategy reflects your business, not a generic playbook.</p>
      </div>
      <div class="how-step reveal" style="--d:700">
        <div class="how-step__num">03</div>
        <h3 class="how-step__title">Shape the plan</h3>
        <p class="how-step__body">You see the draft plan, share your feedback, and we refine it into a smart, sustainable strategy that's ready to put to work.</p>
      </div>
      <div class="how-step reveal" style="--d:1050">
        <div class="how-step__num">04</div>
        <h3 class="how-step__title">Set the systems and guide implementation</h3>
        <p class="how-step__body">Frameworks, tools, and rhythms that make consistent marketing happen. We hold the standard. Your team holds the work, or we help you build one.</p>
      </div>
    </div>
  </div>
</section>

<!-- ============ LEAD MAGNET ============ -->
<section class="leadmag" data-screen-label="09 Lead magnet" data-comment-anchor="leadmag">
  <div class="container">
    <div class="leadmag__inner">
      <div class="reveal">
        <span class="eyebrow eyebrow--show">FREE TOOL</span>
        <h2 class="section-title" style="margin-top:16px">Find your marketing gaps in <span class="hl">5 minutes</span>.</h2>
        <p class="section-intro" style="margin-top:24px; max-width:520px">When the pipeline goes quiet, most business owners know something's off, they just can't see where. The Growth Assessment gives you a quick read on where your marketing is strong and where it's slipping, in under five minutes.</p>
        <div style="margin-top:36px">
          <a href="#" class="btn btn--primary btn--mustard">Take the growth assessment <span class="arrow">→</span></a>
        </div>
      </div>
      <div class="reveal" style="--d:120">
        <div class="leadmag__media leadmag__media--illustration">
          <svg viewBox="0 0 600 430" xmlns="http://www.w3.org/2000/svg" aria-label="Growth Assessment dashboard on an iPad" role="img" style="overflow:visible">
            <defs>
              <linearGradient id="ipad-body" x1="0%" y1="0%" x2="100%" y2="100%">
                <stop offset="0%" stop-color="#FFFFFF"/>
                <stop offset="100%" stop-color="#F0F0F0"/>
              </linearGradient>
            </defs>
            <!-- drop shadow -->
            <ellipse cx="300" cy="422" rx="200" ry="8" fill="rgba(17,13,27,0.15)"/>
            <!-- iPad body -->
            <rect x="24" y="14" width="552" height="398" rx="33" fill="url(#ipad-body)"/>
            <rect x="24" y="14" width="552" height="398" rx="33" fill="none" stroke="#C4C4C4" stroke-width="1.5"/>
            <!-- inner edge highlight -->
            <rect x="25.5" y="15.5" width="549" height="395" rx="32" fill="none" stroke="rgba(255,255,255,0.85)" stroke-width="1"/>
            <!-- screen -->
            <rect x="57" y="27" width="486" height="372" rx="9" fill="#FFFFFF"/>
            <!-- front camera (right edge, landscape) -->
            <circle cx="572" cy="213" r="4" fill="#E8E8E8"/>
            <circle cx="572" cy="213" r="2.2" fill="#D4D4D4"/>
            <!-- power button (top edge, right) -->
            <rect x="468" y="13" width="32" height="2.5" rx="1.25" fill="#BBBBBB"/>
            <!-- volume buttons (top edge, left) -->
            <rect x="120" y="13" width="24" height="2.5" rx="1.25" fill="#BBBBBB"/>
